# SwiftFormat configuration

--swiftversion 5.9

# Indentation
--indent 4
--tabwidth 4
--indentcase false
--ifdef no-indent

# Spacing
--operatorfunc spaced
--nospaceoperators ...,..<
--ranges spaced

# Braces
--allman false
--elseposition same-line
--guardelse auto
--wrapternary default

# Wrapping — leave wrapping decisions to the developer; SwiftFormat only enforces indentation
--wraparguments preserve
--wrapparameters preserve
--wrapcollections preserve
--closingparen balanced
--wrapreturntype preserve
--wrapconditions preserve
--wraptypealiases preserve

# Imports
--importgrouping testable-bottom

# Other
--self remove
--selfrequired
--stripunusedargs closure-only
--decimalgrouping 3,6
--binarygrouping none
--octalgrouping none
--hexgrouping none
--exponentcase lowercase
--exponentgrouping disabled
--fractiongrouping disabled
--hexliteralcase uppercase
--ifdef no-indent
--patternlet hoist
--redundanttype inferred
--semicolons never
--trimwhitespace always
--voidtype void
--yodaswap always

# Excluded files
--exclude Sources/Chrome.h
